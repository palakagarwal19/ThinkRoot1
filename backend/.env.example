# NeuroLead Environment Configuration
# Rename this file to .env and fill in your actual values

# ── Clay API (Primary LLM for email generation via Claygent) ──────────────────
# Get your API key from: https://clay.com → Settings → API
CLAY_API_KEY=

# The ID of a Clay table configured with a Claygent column for email generation
# The table should have columns: first_name, last_name, company, title, industry,
# recent_funding, tech_stack, channel, variant → and a Claygent column: generated_copy
CLAY_TABLE_ID=

# ── Gemini API (Fallback LLM) ─────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Apollo API (Enrichment fallback) ─────────────────────────────────────────
APOLLO_API_KEY=

# ── Path to leads CSV ─────────────────────────────────────────────────────────
LEADS_CSV_PATH=C:\Users\Palak\OneDrive\Desktop\lead app\apollo-contacts-export-(2)-(1)-Default-view-export-1776574386695.csv

# ── Server config ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=4000
